# Agenda de Contactos
# Crea una agenda en consola usando una lista de diccionarios. 
# Funciones: agregar_contacto(), buscar_contacto(nombre)
# , mostrar_todos(), eliminar_contacto(nombre). 
# Menú con while para mantenerla activa. 
# Cada contacto tiene nombre, teléfono y email.

agenda = []

# Agregar contacto
def agregar_contacto():
    nombre = input("Nombre: ")
    email = input("Email: ")
    telefono = input("Teléfono: ")

    contacto = {
        "nombre": nombre,
        "email": email,
        "telefono": telefono
    }

    agenda.append(contacto)
    print("✅ Contacto agregado\n")


# Mostrar todos
def mostrar_todos():
    if not agenda:
        print("⚠️ No hay contactos\n")
        return

    for contacto in agenda:
        print(f"Nombre: {contacto['nombre']}")
        print(f"Email: {contacto['email']}")
        print(f"Teléfono: {contacto['telefono']}")
        print("-" * 20)


# Buscar contacto
def buscar_contacto(nombre):
    for contacto in agenda:
        if contacto["nombre"].lower() == nombre.lower():
            print("🔍 Contacto encontrado:")
            print(f"Nombre: {contacto['nombre']}")
            print(f"Email: {contacto['email']}")
            print(f"Teléfono: {contacto['telefono']}\n")
            return

    print("❌ Contacto no encontrado\n")


# Eliminar contacto
def eliminar_contacto(nombre):
    for contacto in agenda:
        if contacto["nombre"].lower() == nombre.lower():
            agenda.remove(contacto)
            print("🗑️ Contacto eliminado\n")
            return

    print("❌ No se encontró el contacto\n")


# Menú
def mostrar_menu():
    while True:
        print("1. Agregar contacto")
        print("2. Buscar contacto")
        print("3. Mostrar todos")
        print("4. Eliminar contacto")
        print("5. Salir")

        opcion = input("Elige una opción: ")

        if opcion == "1":
            agregar_contacto()

        elif opcion == "2":
            nombre = input("Nombre a buscar: ")
            buscar_contacto(nombre)

        elif opcion == "3":
            mostrar_todos()

        elif opcion == "4":
            nombre = input("Nombre a eliminar: ")
            eliminar_contacto(nombre)

        elif opcion == "5":
            print("👋 Saliendo...")
            break

        else:
            print("⚠️ Opción inválida\n")


# Ejecutar programa
mostrar_menu()